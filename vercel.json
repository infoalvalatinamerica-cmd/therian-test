{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/portada_producto.html" },
    { "src": "/quiz", "dest": "/quiz.html" },
    { "src": "/resultado", "dest": "/quiz.html" }
  ]
}
